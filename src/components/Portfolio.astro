---
import Base from '../layouts/Base.astro';
const { t, altUrl, currentUrl } = Astro.props;

const icons = {
  code: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  rocket: '<path d="M4.5 16.5c-1.5 1.3-2 5-2 5s3.7-.5 5-2c.7-.8.7-2 0-2.8-.8-.7-2.1-.7-3 .8Z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2Z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.09 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.09-1.62 0-5 0-5"/>',
  network: '<rect x="9" y="2" width="6" height="6" rx="1"/><rect x="2" y="16" width="6" height="6" rx="1"/><rect x="16" y="16" width="6" height="6" rx="1"/><path d="M12 8v4m0 0H5v4m7-4h7v4"/>',
  server: '<rect x="3" y="4" width="18" height="7" rx="2"/><rect x="3" y="13" width="18" height="7" rx="2"/><circle cx="7" cy="7.5" r="0.8"/><circle cx="7" cy="16.5" r="0.8"/>',
  lock: '<rect x="4" y="10" width="16" height="10" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/>',
  battery: '<rect x="2" y="8" width="17" height="8" rx="2"/><line x1="22" y1="11" x2="22" y2="13"/><path d="M6 10.5v3m3-3v3m3-3v3"/>',
  search: '<circle cx="11" cy="11" r="7"/><path d="m21 21-4.35-4.35"/>',
  blueprint: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>',
  code2: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  rocket2: '<path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2Z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.09 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.09-1.62 0-5 0-5"/>',
  support: '<circle cx="12" cy="12" r="9"/><path d="M12 8v4l2.5 2.5"/>',
};
---
<Base t={t} altUrl={altUrl} currentUrl={currentUrl}>
  <main>
    <!-- HERO -->
    <section class="hero" id="inicio">
      <canvas id="binary-canvas" aria-hidden="true"></canvas>
      <div class="container hero-content">
        <span class="badge">{t.hero.badge}</span>
        <span class="greeting">{t.hero.greeting}</span>
        <h1>{t.hero.name}</h1>
        <p class="typewriter-line">
          {t.hero.rolePrefix} <span class="tw" id="tw" data-roles={JSON.stringify(t.hero.roles)}></span><span class="caret"></span>
        </p>
        <p class="description">{t.hero.description}</p>
        <div class="hero-ctas">
          <a class="btn btn-primary" href="mailto:kevin@010204.best">{t.hero.ctaPrimary} <span class="arrow">→</span></a>
          <a class="btn btn-ghost" href="#proyectos">{t.hero.ctaSecondary}</a>
        </div>
        <div class="stats">
          {t.hero.stats.map((s, i) => (
            <div class="stat reveal" style={`--d:${i * 0.09}s`}>
              <div class="value" data-count={s.value} data-prefix={s.prefix || ''} data-suffix={s.suffix}>0</div>
              <div class="label">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
      <div class="scroll-hint">
        <span>{t.hero.scroll}</span>
        <svg class="chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
    </section>

    <!-- SERVICES -->
    <section id="servicios">
      <div class="container">
        <div class="section-head reveal">
          <span class="badge">{t.services.badge}</span>
          <h2>{t.services.title} <span class="grad">{t.services.titleAccent}</span></h2>
          <p class="lead">{t.services.lead}</p>
        </div>
        <div class="cards-3">
          {t.services.items.map((s, i) => (
            <div class="card reveal" style={`--d:${(i % 3) * 0.1}s`}>
              <div class="icon">
                <svg width="23" height="23" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={icons[s.icon]} />
              </div>
              <h3>{s.title}</h3>
              <p>{s.text}</p>
              <div class="tags">{s.tags.map((tag) => <span class="tag">{tag}</span>)}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- PROCESS -->
    <section id="proceso">
      <div class="container">
        <div class="section-head reveal">
          <span class="badge">{t.process.badge}</span>
          <h2>{t.process.title} <span class="grad">{t.process.titleAccent}</span></h2>
          <p class="lead">{t.process.lead}</p>
        </div>
        <div class="process-grid">
          {t.process.steps.map((s, i) => (
            <div class="step reveal" style={`--d:${i * 0.1}s`}>
              <div class="num">{s.num}</div>
              <div class="icon">
                <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={icons[s.icon]} />
              </div>
              <h3>{s.title}</h3>
              <p>{s.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- PROJECTS -->
    <section id="proyectos">
      <div class="container">
        <div class="section-head reveal">
          <span class="badge">{t.projects.badge}</span>
          <h2>{t.projects.title} <span class="grad">{t.projects.titleAccent}</span></h2>
          <p class="lead">{t.projects.lead}</p>
        </div>
        <div class="cards-2">
          {t.projects.items.map((p, i) => (
            <div class="card project-card reveal" style={`--d:${(i % 2) * 0.12}s`}>
              <div class="mockup" aria-hidden="true">
                <div class="mock-bar">
                  <span class="dot"></span><span class="dot"></span><span class="dot"></span>
                  {p.mockup === 'terminal'
                    ? <span class="url">kevin@010204 — zsh</span>
                    : <span class="url">010204.best</span>}
                </div>
                <div class="mock-body">
                  {p.mockup === 'terminal' && (
                    <>
                      <span class="tline"><span class="p">$</span> dig 010204.best +dnssec</span>
                      <span class="tline"><span class="dim">;; flags: ad —</span> <span class="ok">DNSSEC ✓</span></span>
                      <span class="tline"><span class="p">$</span> curl -w "%&lbrace;time_total&rbrace;" -so /dev/null https://010204.best</span>
                      <span class="tline"><span class="ok">0.043s — edge ✓</span></span>
                      <span class="tline"><span class="p">$</span> git push · <span class="ok">deploy automático ✓</span></span>
                    </>
                  )}
                  {p.mockup === 'network' && (
                    <svg class="mock-net" viewBox="0 0 300 130">
                      <line x1="150" y1="34" x2="60" y2="96" /><line x1="150" y1="34" x2="120" y2="96" /><line x1="150" y1="34" x2="180" y2="96" /><line x1="150" y1="34" x2="240" y2="96" />
                      <circle class="core" cx="150" cy="30" r="13" /><circle cx="60" cy="100" r="9" /><circle cx="120" cy="100" r="9" /><circle cx="180" cy="100" r="9" /><circle cx="240" cy="100" r="9" />
                    </svg>
                  )}
                  {p.mockup === 'containers' && (
                    <div class="mock-containers">
                      <div class="box"></div><div class="box"></div><div class="box"></div><div class="box"></div>
                      <div class="box"></div><div class="box"></div><div class="box"></div><div class="box"></div>
                    </div>
                  )}
                  {p.mockup === 'gallery' && (
                    <div class="mock-gallery">
                      <div class="ph"></div><div class="ph"></div><div class="ph"></div><div class="ph"></div>
                      <div class="ph"></div><div class="ph"></div><div class="ph"></div><div class="ph"></div>
                    </div>
                  )}
                  {p.mockup === 'shield' && (
                    <div class="mock-shield">
                      <span class="ring r1"></span><span class="ring r2"></span>
                      <svg width="46" height="46" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 8.5-7 10-4-1.5-7-5.5-7-10V6l7-3Z"/><path d="m9.5 12 2 2 3.5-4"/></svg>
                    </div>
                  )}
                  {p.mockup === 'pulse' && (
                    <div class="mock-pulse">
                      <svg viewBox="0 0 300 100" preserveAspectRatio="none">
                        <path d="M0 55 L60 55 L75 25 L92 80 L108 40 L122 55 L190 55 L205 30 L220 72 L235 55 L300 55" />
                      </svg>
                    </div>
                  )}
                </div>
              </div>
              <div class="project-info">
                <div class="project-top">
                  <span class="project-cat">{p.category}</span>
                  {p.live && <span class="live-badge">{t.projects.live}</span>}
                </div>
                <h3>{p.title}</h3>
                <p>{p.text}</p>
                <div class="tags">{p.tags.map((tag) => <span class="tag">{tag}</span>)}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- STACK -->
    <section id="stack">
      <div class="container">
        <div class="section-head reveal">
          <span class="badge">{t.stack.badge}</span>
          <h2>{t.stack.title} <span class="grad">{t.stack.titleAccent}</span></h2>
          <p class="lead">{t.stack.lead}</p>
        </div>
        <div class="stack-groups">
          {t.stack.groups.map((g, i) => (
            <div class="stack-group reveal" style={`--d:${(i % 2) * 0.1}s`}>
              <h3>{g.name}</h3>
              <div class="chips">{g.items.map((item) => <span class="chip">{item}</span>)}</div>
            </div>
          ))}
        </div>
      </div>
      <div class="marquee" aria-hidden="true">
        <div class="marquee-track">
          {[...t.stack.marquee, ...t.stack.marquee].map((m) => <span>{m}</span>)}
        </div>
      </div>
    </section>

    <!-- ABOUT -->
    <section id="sobre-mi">
      <div class="container">
        <div class="about-wrap reveal">
          <span class="badge">{t.about.badge}</span>
          <h2>{t.about.title} <span class="grad">{t.about.titleAccent}</span></h2>
          {t.about.paragraphs.map((p) => <p>{p}</p>)}
        </div>
      </div>
    </section>

    <!-- CONTACT -->
    <section id="contacto">
      <div class="container">
        <div class="contact-card reveal">
          <span class="badge">{t.contact.badge}</span>
          <h2>{t.contact.title} <span class="grad">{t.contact.titleAccent}</span></h2>
          <p class="lead">{t.contact.lead}</p>
          <a class="contact-email" href="mailto:kevin@010204.best">kevin@010204.best</a>
          <div class="contact-links">
            <a class="btn btn-primary" href="mailto:kevin@010204.best">{t.contact.cta} <span class="arrow">→</span></a>
            {t.contact.links.map((l) => (
              <a class="btn btn-ghost" href={l.url} target="_blank" rel="noopener noreferrer">{l.label}</a>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>
</Base>
